# BSR-generated packages (@buf/*) resolve from Buf's npm registry, not npmjs.
# Without this, CI and Cloudflare Workers Builds 404 on @buf/loci_loci-proto...
# (it only worked locally via a global ~/.npmrc). The loci-proto module is
# public, so no auth token is required.
@buf:registry=https://buf.build/gen/npm/v1/
